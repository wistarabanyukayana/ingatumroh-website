# Supabase Postgres connection string.
# Use the *transaction pooler* URL (port 6543) — required for Cloudflare Workers.
# Supabase dashboard → Project Settings → Database → Connection string → Transaction.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Supabase project (Auth for /admin + Storage for images).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
